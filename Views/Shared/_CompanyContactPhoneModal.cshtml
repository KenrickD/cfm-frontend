@model cfm_frontend.ViewModels.CompanyContactAddViewModel

<!-- Phone Modal -->
<div class="modal fade" id="phoneModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Phone</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="phoneIndex" value="">
                <input type="hidden" id="phoneId" value="0">

                <div class="mb-3">
                    <label for="phoneType" class="form-label">
                        Phone Type <span class="text-danger">*</span>
                    </label>
                    <select class="form-select" id="phoneType" data-searchable="true" required>
                        <option value="">Mobile</option>
                        @if (Model?.PhoneTypes != null)
                        {
                            foreach (var type in Model.PhoneTypes)
                            {
                                <option value="@type.Value">@type.Text</option>
                            }
                        }
                    </select>
                    <div class="invalid-feedback" id="phoneTypeError"></div>
                </div>

                <div class="mb-3">
                    <label for="phoneNumber" class="form-label">
                        Phone Number <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           class="form-control"
                           id="phoneNumber"
                           placeholder="e.g. +62 882 367 6780"
                           required>
                    <div class="invalid-feedback" id="phoneNumberError"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Main Phone?</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="isMainPhone">
                        <label class="form-check-label" for="isMainPhone">
                            Yes
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="savePhoneBtn">
                    <i class="ti ti-device-floppy me-1"></i>
                    Save
                </button>
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">
                    <i class="ti ti-x me-1"></i>
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>
