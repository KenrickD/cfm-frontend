@model cfm_frontend.ViewModels.JobCodeEditViewModel
@{
    ViewBag.Title = "Edit Job Code";
    ViewBag.pTitle = "Job Code Management";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Parse estimation time (format: "days,hours,minutes" e.g., "0,2,30")
    var estimationTime = Model.JobCode?.EstimationTime ?? "";
    var days = 0;
    var hours = 0;
    var minutes = 0;

    if (!string.IsNullOrEmpty(estimationTime))
    {
        var parts = estimationTime.Split(',');
        if (parts.Length >= 3)
        {
            int.TryParse(parts[0].Trim(), out days);
            int.TryParse(parts[1].Trim(), out hours);
            int.TryParse(parts[2].Trim(), out minutes);
        }
    }
}

@section styles {
    <style>
        .required-field::after {
            content: " *";
            color: #dc3545;
        }

        .time-input-group {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .time-input-item {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .time-input-item label {
            font-size: 12px;
            margin-bottom: 5px;
            font-weight: 500;
        }

        .time-input-item input {
            text-align: center;
        }
    </style>
}

<div class="row">
    <div class="col-sm-12">
        <!-- Page Header -->
        <div class="page-header-title mb-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="m-b-10">Edit Job Code - @Model.JobCode?.Name</h5>
                    <p class="m-b-0 text-muted">Update the job code details</p>
                </div>
                <div>
                    <a href="@Url.Action("Index", "JobCode")" class="btn btn-outline-secondary btn-sm">
                        <i class="ti ti-arrow-left me-1"></i>
                        Back to List
                    </a>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-1">Job Code Information</h5>
                <p class="text-muted mb-0 small">Update the details for this job code</p>
            </div>
            <div class="card-body">

            <form id="editJobCodeForm">
                <input type="hidden" id="idJobCode" name="idJobCode" value="@Model.JobCode?.IdJobCode">
                <input type="hidden" id="materialTypeId" name="materialTypeId" value="@Model.JobCode?.MaterialTypeId">

                <div class="row">
                    <!-- Name -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold required-field">Name</label>
                        <input type="text" class="form-control form-control-sm" id="name" name="name" value="@Model.JobCode?.Name" placeholder="Enter job code name" required>
                        <div class="invalid-feedback">Please enter a job code name.</div>
                    </div>

                    <!-- Group -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold required-field">Group</label>
                        <select class="form-select form-select-sm" id="group" name="group" required>
                            <option value="">Select Group</option>
                            @if (Model.Groups != null && Model.Groups.Any())
                            {
                                foreach (var group in Model.Groups)
                                {
                                    <option value="@group.Id" selected="@(Model.JobCode?.Group == group.Name ? "selected" : null)">@group.Name</option>
                                }
                            }
                        </select>
                        <div class="invalid-feedback">Please select a group.</div>
                    </div>

                    <!-- Description -->
                    <div class="col-12 mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea class="form-control form-control-sm" id="description" name="description" rows="3" placeholder="Enter description (optional)">@Model.JobCode?.Description</textarea>
                    </div>

                    <!-- Labor/Material -->
                    <div class="col-12 mb-3">
                        <label class="form-label fw-semibold required-field">Labor/Material?</label>
                        <div class="mt-2">
                            @if (Model.MaterialLabels != null && Model.MaterialLabels.Any())
                            {
                                var index = 0;
                                foreach (var label in Model.MaterialLabels)
                                {
                                    var isChecked = Model.JobCode?.LaborOrMaterial == label.Value;
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="laborOrMaterial" id="laborMaterial@(index)" value="@label.Id" @(isChecked ? "checked" : "")>
                                        <label class="form-check-label" for="laborMaterial@(index)">
                                            @label.Label
                                        </label>
                                    </div>
                                    index++;
                                }
                            }
                            else
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="laborOrMaterial" id="laborMaterial0" value="Labor" @(Model.JobCode?.LaborOrMaterial == "Labor" ? "checked" : "")>
                                    <label class="form-check-label" for="laborMaterial0">Labor</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="laborOrMaterial" id="laborMaterial1" value="Labor & Material" @(Model.JobCode?.LaborOrMaterial == "Labor & Material" ? "checked" : "")>
                                    <label class="form-check-label" for="laborMaterial1">Labor & Material</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="laborOrMaterial" id="laborMaterial2" value="Material" @(Model.JobCode?.LaborOrMaterial == "Material" ? "checked" : "")>
                                    <label class="form-check-label" for="laborMaterial2">Material</label>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Estimation Time -->
                    <div class="col-12 mb-3">
                        <label class="form-label fw-semibold">Estimation Time</label>
                        <div class="time-input-group">
                            <div class="time-input-item">
                                <label>Days</label>
                                <input type="number" class="form-control form-control-sm" id="estimationTimeDays" name="estimationTimeDays" value="@days" min="0">
                            </div>
                            <div class="time-input-item">
                                <label>Hours</label>
                                <input type="number" class="form-control form-control-sm" id="estimationTimeHours" name="estimationTimeHours" value="@hours" min="0" max="23">
                            </div>
                            <div class="time-input-item">
                                <label>Minutes</label>
                                <input type="number" class="form-control form-control-sm" id="estimationTimeMinutes" name="estimationTimeMinutes" value="@minutes" min="0" max="59">
                            </div>
                        </div>
                    </div>

                    <!-- Unit Price -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold required-field">Unit Price</label>
                        <div class="input-group input-group-sm">
                            <select class="form-select form-select-sm" id="currency" name="currency" required style="max-width: 120px;">
                                @if (Model.Currencies != null && Model.Currencies.Any())
                                {
                                    foreach (var currency in Model.Currencies)
                                    {
                                        <option value="@currency.Id" selected="@(Model.JobCode?.Currency == currency.Value ? "selected" : null)">@currency.Label</option>
                                    }
                                }
                                else
                                {
                                    <option value="" selected>IDR</option>
                                }
                            </select>
                            <input type="number" class="form-control form-control-sm" id="unitPrice" name="unitPrice" value="@Model.JobCode?.UnitPrice" placeholder="0.00" step="0.01" min="0" required>
                        </div>
                        <div class="invalid-feedback">Please enter a unit price.</div>
                    </div>

                    <!-- Measurement Unit -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold required-field">Measurement Unit</label>
                        <select class="form-select form-select-sm" id="measurementUnit" name="measurementUnit" required>
                            <option value="">Select Unit</option>
                            @if (Model.MeasurementUnits != null && Model.MeasurementUnits.Any())
                            {
                                foreach (var unit in Model.MeasurementUnits)
                                {
                                    <option value="@unit.Id" selected="@(Model.JobCode?.MeasurementUnit == unit.Value ? "selected" : null)">@unit.Label</option>
                                }
                            }
                        </select>
                        <div class="invalid-feedback">Please select a measurement unit.</div>
                    </div>

                    <!-- Minimum Stock -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Minimum Stock</label>
                        <input type="number" class="form-control form-control-sm" id="minimumStock" name="minimumStock" value="@(Model.JobCode?.MinimumStock ?? 0)" placeholder="0.00" step="0.01" min="0">
                    </div>
                </div>
            </form>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <a href="@Url.Action("Index", "JobCode")" class="btn btn-outline-secondary">
                        <i class="ti ti-x me-1"></i>
                        Cancel
                    </a>
                    <div>
                        <button type="submit" form="editJobCodeForm" class="btn btn-primary" id="updateButton">
                            <i class="ti ti-check me-1"></i>
                            Update Job Code
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/js/pages/job-code-edit.js"></script>

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            showNotification('@Html.Raw(TempData["ErrorMessage"])', 'error', 'Error');
        </script>
    }
}
