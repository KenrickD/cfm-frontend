@using cfm_frontend.Extensions
@model cfm_frontend.ViewModels.JobCodeViewModel
@{
    ViewBag.Title = "Job Code Management";
    ViewBag.pTitle = "Helpdesk";
    ViewBag.cTitle = "List of Job Code";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
        .group-header {
            background-color: #f8f9fa;
            color: #495057;
            font-weight: 600;
            font-size: 14px;
            text-transform: uppercase;
            padding: 12px 16px;
            border-top: 2px solid #dee2e6;
            border-bottom: 2px solid #dee2e6;
        }

        [data-pc-theme="dark"] .group-header {
            background-color: #2d3748;
            color: #e5e7eb;
            border-color: #4a5568;
        }

        .job-code-name {
            color: #04a9f5;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
        }

        .job-code-name:hover {
            text-decoration: underline;
        }

        .filter-collapse {
            background-color: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 6px;
            padding: 20px;
            margin-bottom: 20px;
        }

        [data-pc-theme="dark"] .filter-collapse {
            background-color: #2d3748;
            border-color: #4a5568;
        }

        .modal-footer.no-divider {
            border-top: none;
        }

        .modal-header.no-divider {
            border-bottom: none;
        }
    </style>
}

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>@ViewBag.cTitle</h5>
                <p>This table shows all job codes with their descriptions, types, and pricing information.</p>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="input-group w-100">
                        <input placeholder="Search by job code name, description, or material type..."
                               type="text" class="form-control" id="mainSearchInput" value="@Model.SearchKeyword">
                        <button type="button" class="btn btn-light d-flex flex-row align-items-center"
                                data-bs-container="body" data-bs-toggle="popover" data-bs-placement="top"
                                data-bs-content="Search" data-bs-trigger="hover" id="searchButton">
                            <i class="ti ti-search"></i>
                        </button>
                        <button type="button" class="btn btn-light d-flex flex-row align-items-center"
                                data-bs-container="body" data-bs-toggle="popover" data-bs-placement="top"
                                data-bs-content="Toggle Filters" data-bs-trigger="hover" id="filterToggleButton">
                            <i class="ti ti-filter"></i>
                        </button>
                        <button type="button" class="btn btn-light d-flex flex-row align-items-center"
                                data-bs-container="body" data-bs-toggle="popover" data-bs-placement="top"
                                data-bs-content="Clear Search" data-bs-trigger="hover" id="clearSearchButton">
                            <i class="ti ti-list-search"></i>
                        </button>
                        @if (Context.Session.CanAdd("Helpdesk", "Job Code Management"))
                        {
                            <button type="button" class="btn btn-light d-flex flex-row align-items-center"
                                    data-bs-container="body" data-bs-toggle="popover" data-bs-placement="top"
                                    data-bs-content="Add New Job Code" data-bs-trigger="hover" id="addJobCodeButton">
                                <i class="ti ti-plus"></i>
                            </button>
                        }
                    </div>
                </div>

                <!-- Filter Section (Collapsible) -->
                <div class="collapse" id="filterSection">
                    <div class="filter-collapse">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Group</label>
                                <select class="form-select" id="groupFilter">
                                    <option value="">All Groups</option>
                                    @if (Model.Groups != null && Model.Groups.Any())
                                    {
                                        foreach (var group in Model.Groups)
                                        {
                                            <option value="@group.Id" selected="@(Model.SelectedGroup == group.Id.ToString() ? "selected" : null)">@group.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Data Status</label>
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" id="showDeletedCheckbox"
                                           @(Model.ShowDeletedData == true ? "checked" : "")>
                                    <label class="form-check-label" for="showDeletedCheckbox">
                                        Show Deleted/Inactive Data
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-12">
                                <button type="button" class="btn btn-primary me-2" id="applyFiltersButton">
                                    <i class="ti ti-check me-2"></i>Apply Filters
                                </button>
                                <button type="button" class="btn btn-light" id="clearFiltersButton">
                                    <i class="ti ti-refresh me-2"></i>Clear Filters
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.JobCodes != null && Model.JobCodes.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover job-code-table mb-0">
                            <thead>
                                <tr style="background-color: #f8f9fa;">
                                    <th style="width: 20%;">Name</th>
                                    <th style="width: 20%;">Description</th>
                                    <th style="width: 12%;">Labor/Material</th>
                                    <th style="width: 13%;">Material Type</th>
                                    <th style="width: 12%;">Estimation Time</th>
                                    <th style="width: 10%;">Unit</th>
                                    <th style="width: 13%;">Unit Price</th>
                                    @if (Context.Session.CanEdit("Helpdesk", "Job Code Management") || Context.Session.CanDelete("Helpdesk", "Job Code Management"))
                                    {
                                        <th style="width: 10%;" class="text-center">Actions</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var groupedJobCodes = Model.JobCodes
                                        .GroupBy(j => j.Group)
                                        .OrderBy(g => g.Key);

                                    foreach (var group in groupedJobCodes)
                                    {
                                        var groupClass = group.Key?.ToLower() ?? "other";
                                        <tr>
                                            <td colspan="@(Context.Session.CanEdit("Helpdesk", "Job Code Management") || Context.Session.CanDelete("Helpdesk", "Job Code Management") ? "8" : "7")" class="group-header @groupClass">
                                                <i class="ti ti-@(groupClass == "electrical" ? "bolt" : "settings") me-2"></i>
                                                @(group.Key ?? "Other")
                                            </td>
                                        </tr>
                                        foreach (var jobCode in group)
                                        {
                                            <tr class="job-code-row">
                                                <td>
                                                    <a href="@Url.Action("Detail", "JobCode", new { id = jobCode.IdJobCode })"
                                                       class="job-code-name">
                                                        @jobCode.Name
                                                    </a>
                                                </td>
                                                <td>
                                                    <small class="text-muted">@(jobCode.Description ?? "-")</small>
                                                </td>
                                                <td>
                                                    @if (jobCode.Label == "Labor & Material")
                                                    {
                                                        <span class="badge bg-light-primary">Labor & Material</span>
                                                    }
                                                    else if (jobCode.Label == "Labor")
                                                    {
                                                        <span class="badge bg-light-info">Labor</span>
                                                    }
                                                    else if (jobCode.Label == "Material")
                                                    {
                                                        <span class="badge bg-light-warning">Material</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">@(jobCode.Label ?? "-")</span>
                                                    }
                                                </td>
                                                <td>
                                                    <small>@(jobCode.MaterialType ?? "-")</small>
                                                </td>
                                                <td>
                                                    <small class="text-muted">@(jobCode.EstimationTime ?? "-")</small>
                                                </td>
                                                <td>
                                                    <span class="badge bg-light text-dark">@(jobCode.MeasurementUnit ?? "-")</span>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(jobCode.UnitPrice))
                                                    {
                                                        <span>@jobCode.UnitPrice</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                @if (Context.Session.CanEdit("Helpdesk", "Job Code Management") || Context.Session.CanDelete("Helpdesk", "Job Code Management"))
                                                {
                                                    <td>
                                                        <div class="grid gap-0 column-gap-2 d-flex flex-row">
                                                            @if (Context.Session.CanEdit("Helpdesk", "Job Code Management"))
                                                            {
                                                                <button class="btn btn-light btn-sm edit-job-code"
                                                                        data-id="@jobCode.IdJobCode"
                                                                        role="button" data-bs-container="body"
                                                                        data-bs-toggle="popover" data-bs-placement="top"
                                                                        data-bs-content="Edit this Job Code" data-bs-trigger="hover">
                                                                    <i class="ti ti-edit-circle"></i>
                                                                </button>
                                                            }
                                                            @if (Context.Session.CanDelete("Helpdesk", "Job Code Management"))
                                                            {
                                                                <button class="btn btn-light btn-sm delete-job-code"
                                                                        data-id="@jobCode.IdJobCode"
                                                                        data-name="@jobCode.Name"
                                                                        data-bs-container="body"
                                                                        data-bs-toggle="popover" data-bs-placement="top"
                                                                        data-bs-content="Delete this Job Code" data-bs-trigger="hover">
                                                                    <i class="ti ti-trash"></i>
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    @await Html.PartialAsync("_Pagination", Model.Paging)
                }
                else
                {
                    <div class="text-center py-4">
                        <div class="text-muted">
                            <i class="ti ti-inbox" style="font-size: 48px; opacity: 0.5;"></i>
                            <p class="mt-2">No job codes found</p>
                            @if (Context.Session.CanAdd("Helpdesk", "Job Code Management"))
                            {
                                <button type="button" class="btn btn-primary mt-2" id="addJobCodeButtonEmpty">
                                    <i class="ti ti-plus me-1"></i>Add New Job Code
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade modal-animate" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header no-divider">
                <div class="d-flex flex-row align-items-center text-danger">
                    <i class="ti ti-alert-octagon me-2 fs-5"></i>
                    <span class="text-lg fw-semibold">Warning</span>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <h5>You are about to delete Job Code &mdash; <span id="jobCodeNameToDelete"></span></h5>
                <p>Are you sure you want to delete this Job Code? This action cannot be undone and may affect existing work requests.</p>
            </div>
            <div class="modal-footer no-divider bg-gray-100">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between gap-3">
                        <button type="button" class="btn btn-outline-secondary rounded-3 w-100 d-flex justify-content-center align-items-center" data-bs-dismiss="modal">
                            <i class="ti ti-x me-2"></i>
                            Cancel
                        </button>
                        <button type="button" class="btn btn-danger rounded-3 w-100 d-flex justify-content-center align-items-center" id="confirmDeleteBtn">
                            <i class="ti ti-trash me-2"></i>
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/js/pages/job-code-list.js"></script>

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            showNotification('@Html.Raw(TempData["ErrorMessage"])', 'error', 'Error');
        </script>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            showNotification('@Html.Raw(TempData["SuccessMessage"])', 'success', 'Success');
        </script>
    }
}
