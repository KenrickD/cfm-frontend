@using cfm_frontend.Extensions
@model cfm_frontend.ViewModels.JobCodeDetailViewModel
@{
    ViewBag.Title = "Job Code Details";
    ViewBag.pTitle = "Job Code Management";
    ViewBag.pTitleUrl = Url.Action("Index", "JobCode");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <style>
        .form-control-sm {
            font-size: 0.875rem;
        }

        .card-header {
            background-color: #f8f9fa;
            border-bottom: 1px solid #e9ecef;
        }

        [data-pc-theme="dark"] .card-header {
            background-color: #2d3748;
            border-bottom-color: #4a5568;
        }
    </style>
}

<div class="row">
    <div class="col-sm-12">
        <!-- Page Header -->
        <div class="page-header-title mb-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="m-b-10">Job Code Details</h5>
                    <p class="m-b-0 text-muted">View job code information</p>
                </div>
                <div>
                    <a href="@Url.Action("Index", "JobCode")" class="btn btn-outline-secondary btn-sm">
                        <i class="ti ti-arrow-left me-1"></i>
                        Back to List
                    </a>
                </div>
            </div>
        </div>

        @if (Model.JobCode != null)
        {
            <!-- Job Code Information -->
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-1">Job Code Information</h5>
                    <p class="text-muted mb-0 small">Basic details about this job code</p>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Name</label>
                            <input type="text" class="form-control form-control-sm" value="@Model.JobCode.Name" readonly>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Group</label>
                            <input type="text" class="form-control form-control-sm" value="@Model.JobCode.Group" readonly>
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control form-control-sm" rows="3" readonly>@(string.IsNullOrEmpty(Model.JobCode.Description) ? "-" : Model.JobCode.Description)</textarea>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Labor/Material</label>
                            <div>
                                <span class="badge bg-light-info">@Model.JobCode.LaborOrMaterial</span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Material Type</label>
                            <input type="text" class="form-control form-control-sm" value="@(string.IsNullOrEmpty(Model.JobCode.MaterialType) ? "-" : Model.JobCode.MaterialType)" readonly>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Estimation Time</label>
                            <input type="text" class="form-control form-control-sm" value="@(string.IsNullOrEmpty(Model.JobCode.EstimationTime) ? "Not specified" : Model.JobCode.EstimationTime)" readonly>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Unit Price</label>
                            <input type="text" class="form-control form-control-sm" value="@Model.JobCode.Currency @Model.JobCode.UnitPrice?.ToString("N2")" readonly>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Measurement Unit</label>
                            <input type="text" class="form-control form-control-sm" value="@Model.JobCode.MeasurementUnit" readonly>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Minimum Stock</label>
                            <input type="text" class="form-control form-control-sm" value="@Model.JobCode.MinimumStock?.ToString("N2")" readonly>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Change History -->
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-1">Change History</h5>
                <p class="text-muted mb-0 small">Track all changes made to this job code</p>
            </div>
            <div class="card-body">
                @if (Model.ChangeHistory != null && Model.ChangeHistory.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered table-sm">
                            <thead>
                                <tr>
                                    <th>Updated By</th>
                                    <th>Updated At</th>
                                    <th>Changed Information</th>
                                    <th>From</th>
                                    <th>To</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var history in Model.ChangeHistory)
                                {
                                    <tr>
                                        <td>@history.UpdatedBy</td>
                                        <td>@history.UpdatedAt?.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>@history.ChangedInformation</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(history.From))
                                            {
                                                <span>@history.From</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(history.To))
                                            {
                                                <span>@history.To</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="ti ti-history" style="font-size: 48px; opacity: 0.5;"></i>
                        <p class="mt-2 mb-0">No change history available yet</p>
                    </div>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <a href="@Url.Action("Index", "JobCode")" class="btn btn-outline-secondary">
                        <i class="ti ti-arrow-left me-1"></i>
                        Back to List
                    </a>
                    <div>
                        @if (Context.Session.CanEdit("Helpdesk", "Job Code Management"))
                        {
                            <a href="@Url.Action("Edit", "JobCode", new { id = Model.JobCode?.IdJobCode })" class="btn btn-outline-primary">
                                <i class="ti ti-edit me-1"></i>
                                Edit Job Code
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            showNotification('@Html.Raw(TempData["ErrorMessage"])', 'error', 'Error');
        </script>
    }
}
