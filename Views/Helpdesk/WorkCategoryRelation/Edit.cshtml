@model cfm_frontend.ViewModels.WorkCategoryRelationEditViewModel

@{
    ViewBag.Title = "Edit This Work Category";
    ViewBag.pTitle = "Work Category Relation List";
    ViewBag.pTitleUrl = "/WorkCategoryRelation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <link rel="stylesheet" href="~/assets/css/components/searchable-dropdown.css" />
    <link rel="stylesheet" href="~/assets/css/components/dual-listbox.css" />
    <link rel="stylesheet" href="~/assets/css/pages/work-category-relation.css" />
}

@Html.AntiForgeryToken()

<div class="row">
    <div class="col-sm-12">
        <!-- Page Header -->
        <div class="page-header-title mb-3">
            <h5 class="m-b-10">Edit This Work Category</h5>
            <p class="m-b-0 text-muted">Update work category relation settings</p>
        </div>

        <div class="card">
            <div class="card-body">
                <form id="editForm">
                    <input type="hidden" id="idWorkCategoryRelation" value="@Model.IdWorkCategoryRelation" />

                    <div class="row">
                        <!-- Work Category -->
                        <div class="col-md-4 mb-3">
                            <label for="workCategorySelect" class="form-label">Work Category <span class="text-danger">*</span></label>
                            <select id="workCategorySelect"
                                    class="form-select"
                                    data-searchable="true"
                                    required>
                                <option value="">- Select Work Category -</option>
                            </select>
                            <div class="invalid-feedback" id="workCategoryError"></div>
                        </div>

                        <!-- Priority Level -->
                        <div class="col-md-4 mb-3">
                            <label for="priorityLevelSelect" class="form-label">Priority Level <span class="text-danger">*</span></label>
                            <select id="priorityLevelSelect"
                                    class="form-select"
                                    data-searchable="true"
                                    required>
                                <option value="">- Select Priority Level -</option>
                            </select>
                            <div class="invalid-feedback" id="priorityLevelError"></div>
                        </div>

                        <!-- PIC -->
                        <div class="col-md-4 mb-3">
                            <label for="picSelect" class="form-label">PIC <span class="text-danger">*</span></label>
                            <select id="picSelect"
                                    class="form-select"
                                    data-searchable="true"
                                    required>
                                <option value="">- Select PIC -</option>
                            </select>
                            <div class="invalid-feedback" id="picError"></div>
                        </div>
                    </div>

                    <!-- Dual Listbox for Properties -->
                    <div class="row">
                        <div class="col-12 mb-3">
                            <label class="form-label">Properties Assignment</label>
                            <p class="text-muted small">Select which properties the chosen PIC can access for this work category</p>
                            <div id="propertiesListbox"></div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="row">
                        <div class="col-12">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary" id="saveBtn">
                                    <i class="ti ti-device-floppy me-1"></i>
                                    Save Work Category
                                </button>
                                <a href="@Url.Action("Index", "WorkCategoryRelation")" class="btn btn-secondary">
                                    <i class="ti ti-x me-1"></i>
                                    Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        // Client context for multi-tab session safety
        window.PageContext = {
            idClient: @(Model?.IdClient ?? 0),
            selectedWorkCategoryId: @(Model?.SelectedWorkCategoryId ?? 0),
            selectedPriorityLevelId: @(Model?.SelectedPriorityLevelId ?? 0),
            selectedPICId: @(Model?.SelectedPICId ?? 0),
            assignedPropertyIds: @Html.Raw(Json.Serialize(Model?.AssignedProperties?.Select(p => p.IdProperty) ?? new List<int>()))
        };
    </script>
    <script src="~/assets/js/components/searchable-dropdown.js"></script>
    <script src="~/assets/js/components/dual-listbox.js"></script>
    <script src="~/assets/js/pages/workcategoryrelation/edit.js"></script>
}
