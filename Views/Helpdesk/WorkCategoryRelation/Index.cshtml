@model cfm_frontend.ViewModels.WorkCategoryRelationViewModel

@{
    ViewBag.Title = "Work Category Relation List";
    ViewBag.pTitle = "Helpdesk";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
    <link rel="stylesheet" href="~/assets/css/pages/work-category-relation.css" />
}

@Html.AntiForgeryToken()

<div class="row">
    <div class="col-sm-12">
        <!-- Page Header -->
        <div class="page-header-title mb-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="m-b-10">List of Work Category Relation</h5>
                    <p class="m-b-0 text-muted">Type keywords to search by Work Category Name, PIC, Priority Level, Location...</p>
                </div>
            </div>
        </div>

        <!-- Search and Add Button -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="search-box-container">
                <div class="input-group">
                    <input type="text"
                           class="form-control"
                           id="searchInput"
                           placeholder="Type keywords to search by Work Category Name, PIC, Priority Level, Location..."
                           value="@Model?.SearchKeyword">
                    <button type="button" class="btn btn-primary" id="searchBtn">
                        <i class="ti ti-search me-1"></i> Search
                    </button>
                </div>
            </div>
            <div>
                <a href="@Url.Action("Add", "WorkCategoryRelation")" class="btn btn-primary">
                    <i class="ti ti-plus me-1"></i>
                    Add New Work Category
                </a>
            </div>
        </div>

        <!-- Total Count -->
        <div class="mb-3">
            @if (Model?.Paging != null && Model.Paging.TotalCount > 0)
            {
                var startRecord = (Model.Paging.CurrentPage - 1) * Model.Paging.PageSize + 1;
                var endRecord = Math.Min(Model.Paging.CurrentPage * Model.Paging.PageSize, Model.Paging.TotalCount);
                <span class="text-muted">Showing total of <strong>@Model.Paging.TotalCount</strong> Work Categories</span>
            }
            else
            {
                <span class="text-muted">Showing total of <strong>0</strong> Work Categories</span>
            }
        </div>

        <!-- List Table -->
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-3"><h6 class="mb-0">Work Category</h6></div>
                    <div class="col-3"><h6 class="mb-0">Priority Level</h6></div>
                    <div class="col-3"><h6 class="mb-0">PIC Name</h6></div>
                    <div class="col-3 text-end"><h6 class="mb-0">Actions</h6></div>
                </div>
            </div>
            <div class="card-body p-0" id="relationListBody">
                @if (Model?.Relations != null && Model.Relations.Any())
                {
                    @foreach (var relation in Model.Relations)
                    {
                        <div class="relation-list-item">
                            <div class="relation-work-category">
                                <a href="@Url.Action("Detail", "WorkCategoryRelation", new { id = relation.IdWorkCategoryRelation })">
                                    @relation.WorkCategoryName
                                </a>
                            </div>
                            <div class="relation-priority-level">@relation.PriorityLevelName</div>
                            <div class="relation-pic-name">@relation.PICName</div>
                            <div class="relation-actions">
                                <a href="@Url.Action("Edit", "WorkCategoryRelation", new { id = relation.IdWorkCategoryRelation })"
                                   class="btn btn-sm btn-primary"
                                   title="Edit">
                                    <i class="ti ti-edit"></i>
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-danger"
                                        onclick="deleteRelation(@relation.IdWorkCategoryRelation, '@Html.Raw(relation.WorkCategoryName?.Replace("'", "\\'") ?? "")')"
                                        title="Delete">
                                    <i class="ti ti-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state py-5" id="emptyState">
                        <i class="ti ti-folder-off"></i>
                        <p>No work category relations found</p>
                    </div>
                }
            </div>
        </div>

        <!-- Pagination -->
        @if (Model?.Paging != null && Model.Paging.TotalPages > 1)
        {
            @await Html.PartialAsync("_Pagination", Model.Paging)
        }
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this work category relation?</p>
                <p class="text-muted small mb-0">
                    <strong id="deleteItemName"></strong>
                </p>
                <p class="text-danger small mt-2 mb-0">
                    <i class="ti ti-alert-triangle me-1"></i>
                    This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        // Pass current state to JavaScript
        window.currentPage = @(Model?.Paging?.CurrentPage ?? 1);
        window.searchKeyword = '@Html.Raw(Model?.SearchKeyword ?? "")';

        // Client context for multi-tab session safety
        window.PageContext = {
            idClient: @(Model?.IdClient ?? 0)
        };
    </script>
    <script src="~/assets/js/pages/workcategoryrelation/index.js"></script>
}
